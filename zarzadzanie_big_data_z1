#Część4 - Wizualizacja
import matplotlib.pyplot as plt

df_regiony = pd.read_sql_query("""
select region, sum(populacja) as populacja from kraje group by region
""", conn)

plt.figure(figsize=(10,6))
plt.bar(df_regiony["region"], df_regiony["populacja"])

plt.title("Populacja według regionów")
plt.xlabel("Region")
plt.ylabel("Populacja")
plt.xticks(rotation=45)

plt.show()
